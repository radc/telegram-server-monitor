# Obrigatórios
TELEGRAM_BOT_TOKEN=coloque_aqui_o_token_do_bot
SERVER_NAME=servidor-gpu-01

# Opcional: caminho do TXT com os inscritos no alerta de boot
AOW_SUBSCRIBERS_FILE=./aow_subscribers.txt

# Opcional: amostragem do /status
STATUS_SAMPLES=5
STATUS_INTERVAL_SECONDS=1

# Opcional: enviar alerta quando o serviço subir
BOOT_ALERT_ON_START=true

# Opcional: nível de log
LOG_LEVEL=INFO
